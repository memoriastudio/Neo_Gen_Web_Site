<section id="contact" class="py-20 bg-background-dark">
  <div
    id="popup"
    class="pointer-events-none fixed inset-0 z-50 flex items-center justify-center bg-primary-950/20 opacity-0 backdrop-blur-sm transition-opacity duration-300"
  >
    <div
      id="popup-content"
      class="flex max-w-xl scale-90 items-start gap-6 rounded-2xl border border-primary-100 bg-white p-10 shadow-2xl transition-transform duration-300"
    >
      <div id="icon-success" class="hidden shrink-0">
        <svg class="text-green-500 h-20 w-20" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-width="2" d="M9 12l2 2 4-4"></path>
        </svg>
      </div>

      <div id="icon-error" class="hidden shrink-0">
        <svg class="text-red-500 h-20 w-20" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-width="2" d="M6 18L18 6M6 6l12 12"
          ></path>
        </svg>
      </div>

      <div class="flex-1">
        <h3 id="popup-title" class="mb-2 text-2xl font-bold text-black"></h3>
        <p id="popup-message" class="text-lg text-gray-800"></p>
      </div>
    </div>
  </div>
  <h2
    class="text-5xl font-black tracking-tight text-white sm:text-6xl md:text-8xl leading-[1.05] text-center mb-12"
  >
    <span
      class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-green-300"
      >Ready to Go Global?</span
    >
  </h2>
  <div class="w-full max-w-3xl mx-auto px-4">
    <div class="glass-card p-8 md:p-12">
      <p class="text-gray-400 mb-8">
        Your content already works. Let's make it work in every language. Apply
        for NeoGen and we'll analyze your channel's dubbing potential — no cost,
        no commitment.
      </p>

      <form id="applicationForm" class="space-y-6">
        <!-- Success Message -->
        <div
          id="successMessage"
          class="hidden text-center py-8 animate-in fade-in zoom-in duration-500"
        >
          <div class="mb-6 flex justify-center">
            <div class="rounded-full bg-primary/20 p-4">
              <span class="material-symbols-outlined text-primary text-5xl">
                check_circle
              </span>
            </div>
          </div>
          <h2 class="text-3xl font-bold text-white mb-4">Application Sent!</h2>
          <p class="text-gray-400 text-lg mb-8">
            Thank you for your interest. Our team will analyze your channel and
            get back to you within 48 hours.
          </p>
          <button
            type="button"
            onclick="location.reload()"
            class="px-8 py-3 bg-white text-black font-bold rounded-xl hover:scale-105 transition-transform"
          >
            Close
          </button>
        </div>

        <div id="formContent" class="space-y-6">
          <!-- Full Name -->
          <div>
            <label
              for="fullName"
              class="block text-sm font-medium text-gray-300 mb-2"
            >
              Full Name
            </label>
            <input
              type="text"
              id="fullName"
              name="fullName"
              required
              placeholder="John Smith"
              class="form-input"
            />
            <p class="hidden text-red-500 text-sm mt-1" id="error-fullName">
              Please enter your full name.
            </p>
          </div>

          <!-- Email -->
          <div>
            <label
              for="email"
              class="block text-sm font-medium text-gray-300 mb-2"
            >
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="form-input"
            />
            <p class="hidden text-red-500 text-sm mt-1" id="error-email">
              A valid contact email is required.
            </p>
          </div>

          <!-- YouTube Channel URL -->
          <div>
            <label
              for="channelUrl"
              class="block text-sm font-medium text-gray-300 mb-2"
            >
              YouTube Channel URL
            </label>
            <input
              type="url"
              id="channelUrl"
              name="channelUrl"
              required
              placeholder="https://youtube.com/@yourchannel"
              class="form-input"
            />
            <p class="hidden text-red-500 text-sm mt-1" id="error-channelUrl">
              Please provide a valid YouTube channel link.
            </p>
          </div>

          <!-- Estimated Monthly Views -->
          <div>
            <label
              for="monthlyViews"
              class="block text-sm font-medium text-gray-300 mb-2"
            >
              Estimated Monthly Views
            </label>
            <select
              id="monthlyViews"
              name="monthlyViews"
              required
              class="form-input bg-background-dark"
            >
              <option value="" disabled selected>Select an option</option>
              <option value="500k_1m">500K – 1M</option>
              <option value="1m_5m">1M – 5M</option>
              <option value="5m_10m">5M – 10M</option>
              <option value="10m_plus">10M+</option>
            </select>
            <p class="hidden text-red-500 text-sm mt-1" id="error-monthlyViews">
              Please select your estimated monthly views.
            </p>
          </div>

          <!-- Content Category -->
          <div>
            <label
              for="category"
              class="block text-sm font-medium text-gray-300 mb-2"
            >
              Content Category
            </label>
            <select id="category" name="category" required class="form-input">
              <option value="" disabled selected>Select an option</option>
              <option value="education">Education</option>
              <option value="documentary">Documentary</option>
              <option value="entertainment">Entertainment</option>
              <option value="gaming">Gaming</option>
              <option value="tech">Tech</option>
              <option value="news">News</option>
              <option value="other">Other</option>
            </select>
            <p class="hidden text-red-500 text-sm mt-1" id="error-category">
              Please select your content category.
            </p>
          </div>

          <!-- Rights Ownership -->
          <div class="space-y-2">
            <label class="block text-sm font-medium text-gray-300">
              Do you own 100% of the rights to your content?
            </label>
            <div class="flex items-center gap-6">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="radio"
                  name="rights"
                  value="yes"
                  required
                  class="accent-primary w-4 h-4"
                />
                <span class="text-gray-300">Yes</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="radio"
                  name="rights"
                  value="no"
                  class="accent-primary w-4 h-4"
                />
                <span class="text-gray-300">No</span>
              </label>
            </div>
            <p class="hidden text-red-500 text-sm mt-1" id="error-rights">
              Please confirm your rights ownership status.
            </p>
          </div>

          <!-- CTA -->
          <div class="pt-4">
            <button
              type="submit"
              class="w-full bg-white text-black font-bold py-4 rounded-xl hover:scale-[1.02] transition-transform"
            >
              Get Your Free Channel Analysis
            </button>
          </div>

          <!-- Trust Elements -->
          <div class="mt-6 space-y-3 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <span class="text-primary">✓</span>
              <span>No upfront cost — ever</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-primary">✓</span>
              <span>Response within 48 hours</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-primary">✓</span>
              <span>Your channel, your content, your audience</span>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  import { actions } from "astro:actions";

  const form = document.getElementById("applicationForm");
  const submitBtn = form?.querySelector('button[type="submit"]');

  const popup = document.getElementById("popup");
  const popupContent = document.getElementById("popup-content");
  const popupTitle = document.getElementById("popup-title");
  const popupMessage = document.getElementById("popup-message");
  const iconSuccess = document.getElementById("icon-success");
  const iconError = document.getElementById("icon-error");

  if (
    form &&
    submitBtn &&
    popup &&
    popupTitle &&
    popupMessage &&
    iconSuccess &&
    iconError
  ) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      let isValid = true;

      const toggleError = (id, show) => {
        const el = document.getElementById(id);
        if (el) {
          el.classList.toggle("hidden", !show);
        }
      };

      const fields = [
        { id: "fullName", errorId: "error-fullName" },
        { id: "email", errorId: "error-email" },
        { id: "channelUrl", errorId: "error-channelUrl" },
        { id: "monthlyViews", errorId: "error-monthlyViews" },
        { id: "category", errorId: "error-category" },
      ];

      fields.forEach((field) => {
        const el = document.getElementById(field.id);
        if (!el || !el.value) {
          toggleError(field.errorId, true);
          isValid = false;
        } else {
          toggleError(field.errorId, false);
        }
      });
      const emailInput = document.getElementById("email");

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!emailInput.value || !emailRegex.test(emailInput.value)) {
        toggleError("error-email", true);
        isValid = false;
      }

      // Radio (rights)
      const rights = document.querySelector('input[name="rights"]:checked');
      if (!rights) {
        toggleError("error-rights", true);
        isValid = false;
      } else {
        toggleError("error-rights", false);
      }

      if (!isValid) return;

      // Estado loading botón
      const originalText = submitBtn.innerText;
      submitBtn.disabled = true;
      submitBtn.innerText = "Sending...";
      submitBtn.classList.add("opacity-70", "cursor-not-allowed");

      const formData = new FormData(form);

      try {
        const { error } = await actions.send(formData);

        if (!error) {
          showPopup("success");
          form.reset();
        } else {
          showPopup("error", error.message);
        }
      } catch (err) {
        showPopup("error", "Connection error. Please check your internet.");
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerText = originalText;
        submitBtn.classList.remove("opacity-70", "cursor-not-allowed");
      }
    });

    function showPopup(type, errorMessage) {
      iconSuccess.classList.add("hidden");
      iconError.classList.add("hidden");

      if (type === "success") {
        iconSuccess.classList.remove("hidden");
        popupTitle.innerText = "Application sent successfully!";
        popupMessage.innerText =
          "Thanks for applying to NeoGen. We’ll review your channel and get back to you within 48 hours.";
      } else {
        iconError.classList.remove("hidden");
        popupTitle.innerText = "Application could not be sent";
        popupMessage.innerText =
          errorMessage ||
          "An unexpected error occurred. Please try again later.";
      }

      popup.classList.remove("opacity-0", "pointer-events-none");
      popupContent.classList.remove("scale-90");
      popupContent.classList.add("scale-100");

      setTimeout(() => {
        popup.classList.add("opacity-0", "pointer-events-none");
        popupContent.classList.remove("scale-100");
        popupContent.classList.add("scale-90");
      }, 5000);
    }
  }
</script>
