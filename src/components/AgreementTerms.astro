<section class="py-28 bg-background-dark border-t border-white/5">
  <div class="mx-auto max-w-5xl px-6">
    <div class="mb-24 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Agreement Structure
      </h2>
      <p class="text-lg text-gray-400">
        Aligned incentives. Transparent terms.
      </p>
    </div>
    <div class="space-y-24">
      <div
        class="timeline-item opacity-0 translate-x-[-200px] transition-all duration-1000 ease-out"
      >
        <div
          class="bg-white/5 border border-white/10 rounded-xl p-8 backdrop-blur"
        >
          <span class="text-primary font-mono text-xl">01</span>
          <h3 class="text-4xl font-bold text-white mt-2 mb-4">
            Zero Upfront Cost
          </h3>
          <p class="text-gray-400 text-xl leading-relaxed">
            Memoria funds 100% of dubbing production, channel setup, and ongoing
            management. You invest nothing financially — we invest in your
            content's global potential.
          </p>
        </div>
      </div>
      <div
        class="timeline-item opacity-0 translate-x-[200px] transition-all duration-1000 ease-out right"
      >
        <div
          class="bg-white/5 border border-white/10 rounded-xl p-8 backdrop-blur"
        >
          <span class="text-primary font-mono text-xl">02</span>
          <h3 class="text-4xl font-bold text-white mt-2 mb-4">Revenue Share</h3>
          <p class="text-gray-400 text-xl leading-relaxed">
            Net revenue from dubbed channels — calculated after taxes —
            including AdSense and sponsorships, is split 50/50. Transparent
            reporting. Structural alignment.
          </p>
        </div>
      </div>
      <div
        class="timeline-item opacity-0 translate-x-[-200px] transition-all duration-1000 ease-out"
      >
        <div
          class="bg-white/5 border border-white/10 rounded-xl p-8 backdrop-blur"
        >
          <span class="text-primary font-mono text-xl">03</span>
          <h3 class="text-4xl font-bold text-white mt-2 mb-4">
            Long-Term Growth
          </h3>
          <p class="text-gray-400 text-xl leading-relaxed">
            As your dubbed channels mature, you can continue compounding
            together — or exercise a structured buyout for full ownership.
          </p>
        </div>
      </div>
      <div
        class="timeline-item opacity-0 translate-x-[200px] transition-all duration-1000 ease-out right"
      >
        <div
          class="bg-white/5 border border-white/10 rounded-xl p-8 backdrop-blur"
        >
          <span class="text-primary font-mono text-xl">04</span>
          <h3 class="text-4xl font-bold text-white mt-2 mb-4">
            Structured Exit
          </h3>
          <p class="text-gray-400 text-xl leading-relaxed">
            Clear buyout clauses protect your brand equity and prevent abandoned
            “zombie channels” in the future.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  const items = document.querySelectorAll(".timeline-item");
  let lastScrollY = window.scrollY;
  let scrollDirection = "down";

  window.addEventListener("scroll", () => {
    if (window.scrollY > lastScrollY) {
      scrollDirection = "down";
    } else {
      scrollDirection = "up";
    }
    lastScrollY = window.scrollY;
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const isRight = entry.target.classList.contains("right");

        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0");
          entry.target.classList.remove("translate-x-[-200px]");
          entry.target.classList.remove("translate-x-[200px]");
          entry.target.classList.add("opacity-100");
          entry.target.classList.add("translate-x-0");
        } else if (scrollDirection === "up") {
          entry.target.classList.remove("opacity-100");
          entry.target.classList.remove("translate-x-0");
          entry.target.classList.add("opacity-0");

          if (isRight) {
            entry.target.classList.add("translate-x-[200px]");
          } else {
            entry.target.classList.add("translate-x-[-200px]");
          }
        }
      });
    },
    {
      root: null,
      rootMargin: "-35% 0px -35% 0px",
      threshold: 0,
    },
  );

  items.forEach((item) => observer.observe(item));
</script>
